# MongoDB connection string (get from https://cloud.mongodb.com or use local MongoDB)
# If the password contains @ # : / ? & etc., URL-encode it in USER:PASSWORD (see Atlas Connect → Drivers).
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/saasschool?retryWrites=true&w=majority&appName=Cluster0"
# Or local MongoDB standalone: mongodb://localhost:27017/schoolsaa?directConnection=true
# Or local MongoDB replica set: mongodb://localhost:27017/schoolsaa?replicaSet=rs0

NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PayU Money (India) — home page “Pay with PayU”; test: https://test.payu.in
PAYU_MERCHANT_KEY=""
PAYU_MERCHANT_SALT=""
# test | production
PAYU_MODE="test"

# ========== Notifications (email + WhatsApp) ==========
# See src/lib/notifications.ts. If nothing is configured, notification calls are safe no-ops.
# NOTIFICATIONS_ENABLED=false turns off all outbound notifications.
NOTIFICATIONS_ENABLED=true

# Email — use SMTP (below) OR POST JSON to EMAIL_WEBHOOK_URL: { "to": ["a@b.com"], "subject", "html" }
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM=""
EMAIL_WEBHOOK_URL=""

# WhatsApp — Meta Cloud API OR POST JSON to WHATSAPP_WEBHOOK_URL: { "to": "9198xxxxxxxx", "body" }
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_WEBHOOK_URL=""

# Extra platform alert inboxes (comma-separated); merged with super_admin users for registration / PayU, etc.
PLATFORM_ALERT_EMAILS=""

# ========== SUPER ADMIN (created by npm run db:seed) ==========
# Email: superadmin@schoolsaas.com
# Password: admin123
# Use these to log in at /login and manage organizations/plans.
