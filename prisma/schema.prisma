// School/Coaching Management SaaS - Production Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============ CORE: Organizations (Schools/Coaching) ============
model Organization {
  id          String   @id @default(cuid()) @map("_id")
  name        String
  slug        String   @unique
  // Unique per school (we will start generating/populating this in the app logic)
  schoolCode  String?
  type        String   // "school" | "coaching"
  email       String
  phone       String?
  address     String?
  city        String?
  state       String?
  country     String   @default("India")
  logo        String?
  website     String?
  // Hex accent for PDFs (e.g. #1e40af). Null = default blue theme.
  pdfAccentColor String?
  // Dashboard sidebar palette: slate | navy | emerald | indigo | rose
  dashboardTheme String? @default("slate")
  status      String   @default("pending") // pending | approved | rejected | suspended
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users            User[]
  subscription     Subscription?
  students        Student[]
  staff           Staff[]
  classes         Class[]
  feePlans        FeePlan[]
  payments        Payment[]
  exams           Exam[]
  libraryBooks    LibraryBook[]
  hostelRooms     HostelRoom[]
  bookProducts    BookProduct[]
  bookSets        BookSet[]
  bookSales       BookSale[]
  transportRoutes   TransportRoute[]
  transportVehicles TransportVehicle[]

  branches        Branch[]
}

// ============ BRANCHES (Tenant sub-division) ============
// A single school (Organization) can have multiple branches.
// We keep `branchId` as a scalar on all tenant tables for now, then will enforce filtering/middleware in API/routes.
model Branch {
  id          String   @id @default(cuid()) @map("_id")
  organizationId String // schoolId

  name        String
  address     String?
  contact     String?

  branchCode  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

// ============ AUTH & USERS ============
// Role: super_admin | school_admin | staff | teacher | student | parent
model User {
  id            String    @id @default(cuid()) @map("_id")
  email         String    @unique
  passwordHash  String
  name          String
  role          String    // super_admin, school_admin, staff, teacher, student, parent
  organizationId String?
  phone         String?
  avatar        String?
  permissionsJson String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
}

// ============ SUBSCRIPTION ============
model SubscriptionPlan {
  id          String   @id @default(cuid()) @map("_id")
  name        String   // Basic, Pro, Enterprise
  slug        String   @unique
  description String?
  price       Float    // monthly in INR
  maxStudents Int      @default(100)
  maxStaff    Int      @default(10)
  features    String?  // JSON array of features
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                String   @id @default(cuid()) @map("_id")
  organizationId    String   @unique
  planId            String
  status            String   @default("active") // active | cancelled | expired | past_due
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  stripeCustomerId  String?
  stripeSubscriptionId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  plan         SubscriptionPlan  @relation(fields: [planId], references: [id])
}

// ============ SCHOOL DATA ============
model Student {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  createdBy      String?
  rollNo         String?
  aadhaarNo      String?
  bloodGroup     String?
  firstName      String
  lastName       String
  email          String?
  phone          String?
  dateOfBirth    DateTime?
  gender         String?
  address        String?
  village        String?
  policeStation  String? // PS
  postOffice     String? // Post
  district       String?
  pinCode        String?
  state          String?
  fatherName     String?
  motherName     String?
  motherPhone    String?
  category       String? // general | obc | sc | st | ews | other (Indian school records)
  guardianName   String?
  guardianPhone  String?
  classId        String?
  image          String?   // profile image URL
  resultToken    String?  @unique // unique token for result page
  status         String   @default("active") // active | inactive | graduated | left
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])
  class          Class?       @relation(fields: [classId], references: [id])
  attendances    Attendance[]
  feePayments    Payment[]
  examResults    ExamResult[]
  bookSales      BookSale[]
  transportAssignments TransportStudentAssignment[]
  hostelAllocations    HostelAllocation[]
}

model Staff {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  employeeId     String?
  firstName      String
  lastName       String
  email          String
  phone          String?
  role           String   // teacher, accountant, admin, etc.
  designation    String?
  // Admin-facing copy of the initially generated login password.
  generatedLoginPassword String?
  joinDate       DateTime?
  salary         Float?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?   @relation(fields: [organizationId], references: [id])
  staffAttendances StaffAttendance[]
  paymentsReceived Payment[] @relation("StaffPayer")
  paymentsCollected Payment[] @relation("CollectorStaff")
}

model Class {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String   // e.g. "Class 10-A", "JEE Batch 1"
  subjects       String?  // comma-separated subjects configured for this class
  section        String?
  academicYear   String?
  capacity       Int?
  room           String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  students     Student[]
}

model FeePlan {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String   // e.g. "Monthly Tuition", "Annual Fee"
  payerType      String   @default("student") // student | staff
  amount         Float
  frequency      String   // one_time | monthly | quarterly | yearly
  classId        String?  // optional: class-specific fee
  dueDay         Int?     // day of month for due
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
}

model Payment {
  id             String    @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  studentId      String?
  staffId        String?
  payerType      String    @default("student") // student | staff
  amount         Float
  paidAt         DateTime  @default(now())
  method         String    // cash | card | upi | bank_transfer
  reference      String?
  status         String    @default("pending") // pending | verified | refunded
  verifiedAt     DateTime? // set when school/coaching admin verifies; receipt only then
  verifiedBy     String?   // user id who verified
  verifiedByName String?
  collectedByStaffId String?
  feePlanId      String?
  // Breakdown for receipts: [{ "label": "Tuition", "amount": 5000, "feePlanId": "..." | null }]
  lineItems      Json?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  student      Student?     @relation(fields: [studentId], references: [id])
  staff        Staff?       @relation("StaffPayer", fields: [staffId], references: [id])
  collectedBy  Staff?       @relation("CollectorStaff", fields: [collectedByStaffId], references: [id])
}

model Attendance {
  id         String   @id @default(cuid()) @map("_id")
  organizationId String?
  studentId String
  branchId  String?
  date       DateTime
  status     String   // present | absent | late | leave
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student? @relation(fields: [studentId], references: [id])

  @@unique([studentId, date])
}

// ============ EXAMINATIONS & RESULTS ============
model Exam {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String   // e.g. "Half Yearly 2024-25"
  examType       String   // mid_term | final | unit_test
  classId        String?
  academicYear   String?
  startDate      DateTime?
  endDate        DateTime?
  status         String   @default("draft") // draft | published
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  subjects      ExamSubject[]
  results       ExamResult[]
}

model ExamSubject {
  id       String @id @default(cuid()) @map("_id")
  examId   String
  organizationId String?
  branchId String?
  name     String   // e.g. "Mathematics", "English"
  maxMarks Float
  order   Int      @default(0)

  exam    Exam?    @relation(fields: [examId], references: [id])
  results ExamResult[]
}

model ExamResult {
  id            String   @id @default(cuid()) @map("_id")
  examId        String
  studentId     String
  subjectId     String
  organizationId String?
  branchId       String?
  marksObtained Float
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exam    Exam?         @relation(fields: [examId], references: [id])
  student Student?      @relation(fields: [studentId], references: [id])
  subject ExamSubject?  @relation(fields: [subjectId], references: [id])

  @@unique([examId, studentId, subjectId])
}

// ============ TEACHER WORKFLOW ============
// Assign teachers (staff with role "teacher") to classes inside a branch.
// Teachers can then enter marks only for assigned classes.
model TeacherAssignment {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String
  teacherStaffId String
  classId        String
  subjects       String?  // comma-separated subjects for this class assignment
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([teacherStaffId, classId, branchId])
}

// Teacher class tracking (start/end time per class session)
model TeacherClassSession {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String
  teacherStaffId String
  classId        String

  startedAt DateTime @default(now())
  endedAt   DateTime?
  verifiedAt DateTime? // admin verified in dashboard

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherStaffId, classId, startedAt])
}

// ============ STAFF ATTENDANCE ============
model StaffAttendance {
  id         String   @id @default(cuid()) @map("_id")
  organizationId String?
  staffId    String
  branchId    String?
  date       DateTime
  status     String   // present | absent | late | leave
  remarks    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  staff Staff? @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

// ============ LIBRARY ============
model LibraryBook {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  title          String
  author         String?
  isbn           String?
  category       String?
  totalCopies     Int     @default(1)
  availableCopies Int    @default(1)
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  issues        LibraryIssue[]
}

model LibraryIssue {
  id         String    @id @default(cuid()) @map("_id")
  bookId     String
  studentId  String?   // or staff
  organizationId String?
  branchId       String?
  issuedAt   DateTime  @default(now())
  dueDate    DateTime?
  returnedAt DateTime?
  status     String    @default("issued") // issued | returned | overdue

  book LibraryBook? @relation(fields: [bookId], references: [id])
}

// ============ HOSTEL ============
model HostelRoom {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String   // e.g. "Block A-101"
  capacity       Int      @default(1)
  currentOccupancy Int    @default(0)
  floor          String?
  rent           Float?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization?     @relation(fields: [organizationId], references: [id])
  allocations  HostelAllocation[]
}

model HostelAllocation {
  id        String    @id @default(cuid()) @map("_id")
  roomId    String
  studentId String
  organizationId String?
  branchId       String?
  fromDate  DateTime  @default(now())
  toDate    DateTime?
  status    String    @default("active")

  room    HostelRoom? @relation(fields: [roomId], references: [id])
  student Student?    @relation(fields: [studentId], references: [id])
}

// ============ BOOK SELLING ============
model BookProduct {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String   // e.g. "Notebook", "Physics Book"
  sku            String?
  price          Float
  stock          Int      @default(0)
  category       String?  // book | copy | stationery
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  sales         BookSaleItem[]
  setItems      BookSetItem[]
}

model BookSale {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  studentId      String?
  bookSetId      String?
  invoiceNo      String?
  soldAt         DateTime @default(now())
  totalAmount    Float
  customerName   String?
  customerPhone  String?
  paymentMethod  String?  // cash | upi | card | bank_transfer | cheque | other
  paymentAcceptedByName    String?  // employee who took payment (display)
  paymentAcceptedByStaffId String?  // optional Staff id when picked from list
  status         String   @default("completed")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  student      Student?      @relation(fields: [studentId], references: [id])
  bookSet      BookSet?      @relation(fields: [bookSetId], references: [id])
  items         BookSaleItem[]
}

model BookSaleItem {
  id        String   @id @default(cuid()) @map("_id")
  saleId    String
  productId String
  organizationId String?
  branchId       String?
  quantity  Int
  unitPrice Float
  amount    Float

  sale    BookSale?     @relation(fields: [saleId], references: [id])
  product BookProduct?  @relation(fields: [productId], references: [id])
}

model BookSet {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  classId        String?
  name           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  items        BookSetItem[]
  sales        BookSale[]
}

model BookSetItem {
  id             String   @id @default(cuid()) @map("_id")
  setId          String
  productId      String
  organizationId String?
  branchId       String?
  quantity       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  set     BookSet?     @relation(fields: [setId], references: [id])
  product BookProduct? @relation(fields: [productId], references: [id])
}

// ============ TRANSPORT ============
model TransportRoute {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  name           String
  description    String?
  fromPlace      String?
  toPlace        String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  vehicles     TransportVehicle[]
  assignments  TransportStudentAssignment[]
}

model TransportVehicle {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  routeId        String?
  label          String
  registrationNo String?
  capacity       Int      @default(40)
  driverName     String?
  driverPhone    String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  route        TransportRoute? @relation(fields: [routeId], references: [id])
  assignments  TransportStudentAssignment[]
}

model TransportStudentAssignment {
  id             String   @id @default(cuid()) @map("_id")
  organizationId String
  branchId       String?
  studentId      String
  routeId        String
  vehicleId      String?
  pickupPoint    String?
  dropPoint      String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student Student         @relation(fields: [studentId], references: [id])
  route   TransportRoute  @relation(fields: [routeId], references: [id])
  vehicle TransportVehicle? @relation(fields: [vehicleId], references: [id])
}
